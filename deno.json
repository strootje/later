{
  "tasks": {
    "dev": "vite dev",
    "build": "vite build"
  },
  "allowScripts": [
    "npm:esbuild@0.27.7",
    "npm:sharp@0.33.5"
  ],
  "workspace": [
    "pkgs/**"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "lib": [
      "deno.ns",
      "deno.unstable",
      "webworker",
      "dom"
    ],
    "types": [
      "vite/client",
      "vite-plugin-pwa/info",
      "vite-plugin-pwa/solid",
      "vite-plugin-pwa/pwa-assets"
    ]
  },
  "fmt": {
    "lineWidth": 120
  },
  "lint": {
    "plugins": [
      "jsr:@ryu/deno-lint-plugin-tailwindcss@0.2.0"
    ]
  }
}
